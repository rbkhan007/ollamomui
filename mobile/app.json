{
  "expo": {
    "name": "OllamoMUI",
    "slug": "ollamomui-mobile",
    "version": "1.0.4",
    "orientation": "portrait",
    "scheme": "ollamomui",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#06060e"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ollamomui.app",
      "icon": "./assets/icon.png"
    },
    "android": {
      "package": "com.ollamomui.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon-foreground.png",
        "backgroundImage": "./assets/adaptive-icon-background.png",
        "backgroundColor": "#0d0d1a"
      },
      "notification": {
        "icon": "./assets/notification-icon.png"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "6eda916e-e96f-4a29-8e38-e8605b42b56c"
      }
    },
    "build": {
      "apk": {
        "android": {
          "buildType": "apk"
        }
      },
      "development": {
        "developmentClient": true,
        "distribution": "internal"
      },
      "preview": {
        "distribution": "internal"
      },
      "production": {}
    },
    "owner": "rhavex"
  }
}
