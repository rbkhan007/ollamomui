# Ollama Emulator Desktop - Environment Variables
# Copy to .env and fill in your values

# API key for the active provider (e.g., OpenRouter)
# Get one at: https://openrouter.ai/keys
OLLAMA_EMU_API_KEY=sk-or-v1-your-key-here

# Active provider name (must match a configured provider)
# Options: openrouter, openai, anthropic, groq, deepseek, gemini, mistral, together
OLLAMA_EMU_PROVIDER=openrouter
