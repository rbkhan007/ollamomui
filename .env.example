# PostgreSQL Database Configuration
# For use with pgAdmin4 or any PostgreSQL client

# Option 1: Individual env vars
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=ollamaemu
PGPASSWORD=ollamaemu
PGDATABASE=ollamaemu

# Option 2: Single connection string (takes precedence)
# OLLAMA_EMU_DATABASE_URL=postgresql://ollamaemu:ollamaemu@127.0.0.1:5432/ollamaemu

# Server Config
OLLAMA_EMU_BIND=127.0.0.1
OLLAMA_EMU_PORT=11434

# Provider Config
OLLAMA_EMU_PROVIDER=openrouter
OLLAMA_EMU_API_KEY=sk-or-v1-your-key-here
