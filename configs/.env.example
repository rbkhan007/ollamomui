# PostgreSQL Database Configuration
# For use with pgAdmin4 or any PostgreSQL client

# Option 1: Individual env vars
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=ollamaemu
PGPASSWORD=ollamaemu
PGDATABASE=ollamaemu

# Option 2: Single connection string (takes precedence)
# OLLAMA_EMU_DATABASE_URL=postgresql://ollamaemu:ollamaemu@127.0.0.1:5432/ollamaemu

# Server Config
OLLAMA_EMU_BIND=127.0.0.1
OLLAMA_EMU_PORT=11434

# Provider Config
OLLAMA_EMU_PROVIDER=openrouter
OLLAMA_EMU_API_KEY=sk-or-v1-your-key-here

# pgvector Configuration
# Embedding backend: "tfidf" (built-in), "sentence-transformers" or "st", "openai" or "api"
OLLAMA_EMU_EMBEDDING_BACKEND=tfidf
# Embedding dimension (must match model: MiniLM=384, text-embedding-3-small=1536)
OLLAMA_EMU_EMBEDDING_DIM=384
# Model name (for sentence-transformers or OpenAI-compatible API)
OLLAMA_EMU_EMBEDDING_MODEL=
# For OpenAI-compatible embedding API
OLLAMA_EMU_EMBEDDING_API_URL=
OLLAMA_EMU_EMBEDDING_API_KEY=

# Chunking Configuration
OLLAMA_EMU_CHUNK_SIZE=512
OLLAMA_EMU_CHUNK_OVERLAP=64

# RAG Search Configuration
OLLAMA_EMU_RAG_TOP_K=5
OLLAMA_EMU_RAG_MIN_SIM=0.0
OLLAMA_EMU_RAG_HYBRID_ALPHA=0.7

# Vector Index Configuration
# Index type: "hnsw" (faster, more memory) or "ivfflat" (slower, less memory)
OLLAMA_EMU_RAG_INDEX_TYPE=hnsw
# HNSW parameters
OLLAMA_EMU_RAG_HNSW_M=16
OLLAMA_EMU_RAG_HNSW_EF_CONSTRUCTION=200
# IVFFlat parameters
OLLAMA_EMU_RAG_IVFFLAT_LISTS=100

# ACL & Security Configuration
OLLAMA_EMU_RATE_LIMIT=60
OLLAMA_EMU_RATE_WINDOW=60
OLLAMA_EMU_SESSION_EXPIRY=720
OLLAMA_EMU_MAX_SESSIONS=5
OLLAMA_EMU_ADMIN_EMAIL=
OLLAMA_EMU_IP_BLOCKLIST=
OLLAMA_EMU_IP_ALLOWLIST=

# Payment (SSLCommerz) Configuration
# Get these from the SSLCommerz merchant panel: https://sandbox.sslcommerz.com
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=

# SMTP Configuration (for sending license keys via email)
SMTP_SENDER=noreply@ollamomui.com
SMTP_PASSWORD=your_app_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# App URL (used for payment redirect URLs)
APP_URL=http://localhost:11434
