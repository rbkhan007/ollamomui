# ═══════════════════════════════════════════════════════════════
# OllamoMUI – Production Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your real values.
# NEVER commit secrets to version control.

# ── PostgreSQL ──────────────────────────────────────────────
# Use a managed provider like NeonDB, Supabase, or Railway.
PGHOST=your-db-host.com
PGPORT=5432
PGUSER=ollamaemu
PGPASSWORD=your-strong-password
PGDATABASE=ollamaemu

# ── Server ──────────────────────────────────────────────────
OLLAMA_EMU_BIND=0.0.0.0
OLLAMA_EMU_PORT=11434
OLLAMA_EMU_DISABLE_RATE_LIMIT=1

# ── Provider (default LLM) ─────────────────────────────────
OLLAMA_EMU_PROVIDER=openrouter
OLLAMA_EMU_API_KEY=sk-or-v1-your-key-here

# ── Embedding ──────────────────────────────────────────────
OLLAMA_EMU_EMBEDDING_BACKEND=tfidf
OLLAMA_EMU_EMBEDDING_DIM=384

# ── SSLCommerz (Payment Gateway) ───────────────────────────
# Get credentials from: https://sslcommerz.com
# Sandbox: https://sandbox.sslcommerz.com
SSLCOMMERZ_STORE_ID=your_store_id
SSLCOMMERZ_STORE_PASSWORD=your_store_password

# ── SMTP (License Email Delivery) ──────────────────────────
SMTP_SENDER=noreply@ollamomui.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ── App URL (used for payment redirects & CORS) ────────────
APP_URL=https://api.ollamomui.com
