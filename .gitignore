# OllamoMUI .gitignore
# Security: Never commit API keys, tokens, passwords, or database files.

# =====================
# Python
# =====================
__pycache__/
*.py[cod]
*.egg-info/
*.egg
*.whl
dist/
build/
*.spec
*.db
*.sqlite
*.sqlite3
_rag_tmp/
*.pyc
.venv/
venv/

# =====================
# Node / Frontend
# =====================
node_modules/
frontend/out/
frontend/.next/
frontend/next-env.d.ts
frontend/next.log
frontend/*.tsbuildinfo
frontend/src/generated/
.expo/
.expo-shared/
npm-debug.*
mobile/.expo/
mobile/node_modules/
mobile/dist/

# =====================
# Environment & Secrets
# =====================
.env
.env.local
.env.development
.env.production
.env.test
device.json

# =====================
# IDE / Editor
# =====================
.idea/
.vscode/
*.swp
*.swo
*~
*.iml

# =====================
# OS Files
# =====================
Thumbs.db
.DS_Store
Desktop.ini
ehthumbs.db

# =====================
# Build Artifacts
# =====================
*.manifest
*.log
*.tmp
*.temp
*.err
*.out

# =====================
# Notebook checkpoints
# =====================
.ipynb_checkpoints/

# =====================
# Temp / Logs
# =====================
temp/
curl*

# =====================
# IDE / Editor
# =====================
.opencode/

# =====================
# Release binaries (distributed via GitHub Releases)
# =====================
software.exe
OllamaEmu.exe
Ollama_Emulator.exe
*.apk

# =====================
# Platform tools (Android SDK)
# =====================
platform-tools/
